@PACKAGE_INIT@

# ------------------------------------------------------------
# Architecture metadata (useful for consumers)
# ------------------------------------------------------------
set(robot_middleware_PLATFORM "pico-armv6m")

# ------------------------------------------------------------
# Import the targets file generated during installation
# ------------------------------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/robot_middlewareTargets.cmake")

# ------------------------------------------------------------
# Provide include directory variable for consumers
# ------------------------------------------------------------
set(robot_middleware_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/include")
